datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum BatResult {
  SINGLE
  DOUBLE
  TRIPLE
  HOME_RUN
  INFIELD_HIT
  GROUND_OUT_1
  GROUND_OUT_3
  GROUND_OUT_4
  GROUND_OUT_5
  GROUND_OUT_6
  FLY_OUT_7
  FLY_OUT_8
  FLY_OUT_9
  FLY_OUT_78
  FLY_OUT_89
  LINE_OUT_3
  LINE_OUT_4
  LINE_OUT_5
  LINE_OUT_6
  STRIKEOUT
  WALK
  HIT_BY_PITCH
  REACH_ON_ERROR
  SACRIFICE_BUNT
  SACRIFICE_FLY
  DOUBLE_PLAY
  FIELDERS_CHOICE
}

model Match {
  id           Int           @id @default(autoincrement())
  ownerId      String
  title        String
  status       String        @default("IN_PROGRESS")
  date         DateTime      @default(now())
  homeTeamName String
  awayTeamName String
  homeScore    Int           @default(0)
  awayScore    Int           @default(0)
  createdAt    DateTime      @default(now())
  innings      Inning[]
  players      MatchPlayer[]
  batRecords   BatRecord[]
  pitRecords   PitchRecord[]
}

model MatchPlayer {
  id          Int    @id @default(autoincrement())
  matchId     Int
  match       Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId    String @default("")
  name        String
  team        String
  position    String @default("")
  backNumber  String @default("")
  lineupOrder Int    @default(0)
}

model Inning {
  id      Int   @id @default(autoincrement())
  matchId Int   @unique
  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  home1   Int?
  home2   Int?
  home3   Int?
  home4   Int?
  home5   Int?
  home6   Int?
  home7   Int?
  home8   Int?
  home9   Int?
  home10  Int?
  home11  Int?
  home12  Int?
  away1   Int?
  away2   Int?
  away3   Int?
  away4   Int?
  away5   Int?
  away6   Int?
  away7   Int?
  away8   Int?
  away9   Int?
  away10  Int?
  away11  Int?
  away12  Int?
}

model BatRecord {
  id         Int       @id @default(autoincrement())
  matchId    Int
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId   String    @default("")
  playerName String
  position   String    @default("")
  batOrder   Int       @default(0)
  inningNo   Int
  result     BatResult
}

model PitchRecord {
  id         Int    @id @default(autoincrement())
  matchId    Int
  match      Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId   String @default("")
  playerName String
  team       String @default("HOME")
  innings    Float  @default(0)
  hits       Int    @default(0)
  runs       Int    @default(0)
  earnedRuns Int    @default(0)
  walks      Int    @default(0)
  strikeouts Int    @default(0)
  homeRuns   Int    @default(0)
}
