# 복사:  cp .env.example .env
# 비밀·개인 설정은 .env 에만 두고 Git에는 커밋하지 않음 (.gitignore)

# === 팀 공용 DB (원격 Postgres 하나에 모두 연결) ===
# Neon / Supabase / AWS RDS 등에서 Connection string 발급 후 아래에 붙인다.
# 로컬 DB를 쓸 때는 이 줄을 지우거나 주석 처리하고, 아래 로컬용만 쓴다.
#
# AWS RDS 예시 (TLS, 스키마 public):
# DATABASE_URL="postgresql://USER:PASSWORD@your-rds.xxx.ap-northeast-2.rds.amazonaws.com:5432/dbname?schema=public&sslmode=require"
# RDS에 스키마 반영: yarn db:migrate:deploy  (또는 npx prisma migrate deploy)
# 상세: docs/database-aws-rds.md
#
# DATABASE_URL="postgresql://USER:PASSWORD@호스트:5432/DB이름?schema=public&sslmode=require"

# === 로컬 Postgres (PC마다 따로 — 팀 DB와 공유되지 않음) ===
DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/baseball_scoreboard?schema=public"

PORT=3001
CORS_ORIGIN=http://localhost:3490,http://localhost:5173,http://localhost:5174

# --- 프론트(Vite) — 로컬 ---
VITE_DISABLE_SCOREBOARD_MOCK=true
VITE_SCOREBOARD_API_BASE=http://localhost:3001/api/scoreboard/game

# 로컬에서만: Vite가 /api/scoreboard 를 API 서버로 넘김
# VITE_SCOREBOARD_API_PROXY_TARGET=http://localhost:3001
